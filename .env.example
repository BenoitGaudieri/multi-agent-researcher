# ── LLM & Embeddings (Ollama) ─────────────────────────────────────────────────
RAG_LLM_MODEL=llama3.2
RAG_EMBED_MODEL=nomic-embed-text

# ── FAISS index location ───────────────────────────────────────────────────────
RAG_INDEX_DIR=./faiss_db
RAG_COLLECTION=default

# ── Retrieval ─────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# ── Web search ────────────────────────────────────────────────────────────────
# Get a free key at https://tavily.com — if unset, falls back to DuckDuckGo
TAVILY_API_KEY=

# ── Web agent results ─────────────────────────────────────────────────────────
WEB_MAX_RESULTS=5

# Folder where web search results are saved as Markdown files
WEB_RESULTS_DIR=./web_results

# Folder where final answers are saved as Markdown files
ANSWERS_DIR=./answers
